# Database
# 네이티브 dev 실행 기준 localhost. 도커 전체 실행(docker-compose.yml) 시 compose가 db로 override함
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=dhyun
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=onyu

# Discord Bot
DISCORD_API_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback
DISCORD_COMMAND_PREFIX=!

# Node Environment
NODE_ENV=development

# Redis
# 네이티브 dev 실행 기준 localhost. 도커 전체 실행(docker-compose.yml) 시 compose가 redis로 override함
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# JWT (for web authentication)
JWT_SECRET=your_jwt_secret_here

# Web Dashboard URL
WEB_URL=http://localhost:4000

# Discord 공개 문의 채널 초대 링크 (웹 "디스코드로 문의" 버튼/푸터 링크 — 미설정 시 숨김)
# 디스코드에서 만료 없는(Expire: Never) 초대를 발급해 입력
NEXT_PUBLIC_DISCORD_SUPPORT_URL=https://discord.gg/your_invite_code
