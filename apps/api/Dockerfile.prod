FROM node:20-alpine AS builder

# Install pnpm
ENV PNPM_HOME="/root/.local/share/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

# Skip husky in Docker build
ENV HUSKY=0

WORKDIR /workspace

# Copy workspace config and lockfile
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY tsconfig.json ./

# Copy workspace package.json files
COPY apps/api/package.json ./apps/api/
COPY libs/shared/package.json ./libs/shared/
COPY libs/bot-api-client/package.json ./libs/bot-api-client/
COPY libs/i18n/package.json ./libs/i18n/

# Install dependencies (cache mount for faster rebuilds)
RUN --mount=type=cache,target=/root/.local/share/pnpm/store pnpm install --frozen-lockfile

# Copy shared library and build
COPY libs/shared ./libs/shared
RUN pnpm --filter @onyu/shared build

# Copy bot-api-client library and build
COPY libs/bot-api-client ./libs/bot-api-client
RUN pnpm --filter @onyu/bot-api-client build

# Copy i18n library
COPY libs/i18n ./libs/i18n

# Copy API source and build
COPY apps/api ./apps/api
WORKDIR /workspace/apps/api
RUN pnpm run build

# Production stage
FROM node:20-alpine

# Install pnpm
ENV PNPM_HOME="/root/.local/share/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@10.11.0 --activate

# Fonts for canvas (Korean + Emoji support)
RUN apk add --no-cache fontconfig font-noto-cjk font-noto-emoji

WORKDIR /workspace

# Copy workspace config and lockfile
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./

# Copy workspace package.json files
COPY apps/api/package.json ./apps/api/
COPY libs/shared/package.json ./libs/shared/
COPY libs/bot-api-client/package.json ./libs/bot-api-client/
COPY libs/i18n/package.json ./libs/i18n/

# Skip husky in production (devDependency)
ENV HUSKY=0

# Install only production dependencies
RUN --mount=type=cache,target=/root/.local/share/pnpm/store pnpm install --frozen-lockfile --prod

# Copy built shared library
COPY --from=builder /workspace/libs/shared/dist ./libs/shared/dist
COPY --from=builder /workspace/libs/shared/package.json ./libs/shared/

# Copy built bot-api-client library
COPY --from=builder /workspace/libs/bot-api-client/dist ./libs/bot-api-client/dist
COPY --from=builder /workspace/libs/bot-api-client/package.json ./libs/bot-api-client/

# Copy i18n locales
COPY --from=builder /workspace/libs/i18n ./libs/i18n

# Copy built API
COPY --from=builder /workspace/apps/api/dist ./apps/api/dist
COPY --from=builder /workspace/apps/api/package.json ./apps/api/

WORKDIR /workspace/apps/api

EXPOSE 3000

CMD ["node", "dist/apps/api/src/main.js"]
