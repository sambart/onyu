# ============================================================
# Production Environment Variables
# 복사하여 .env.prod 로 저장 후 실제 값을 채워 넣으세요.
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# ─── Server ───────────────────────────────────────────────
# 서버 공인 IP 또는 도메인 (예: 123.45.67.89)
SERVER_HOST=YOUR_SERVER_IP

# ─── Node ─────────────────────────────────────────────────
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=dhyun
DATABASE_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_NAME=onyu

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── Discord Bot ──────────────────────────────────────────
DISCORD_API_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_COMMAND_PREFIX=!

# ⚠ 아래 URL을 실제 서버 IP로 변경하세요
DISCORD_CALLBACK_URL=http://YOUR_SERVER_IP:3000/auth/discord/callback

# ─── Bot → API 통신 ─────────────────────────────────────
# Bot과 API 간 내부 통신 인증 키 (임의의 긴 문자열)
BOT_API_KEY=CHANGE_ME_RANDOM_BOT_API_KEY

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET

# ─── Web Dashboard ────────────────────────────────────────
# API CORS origin (웹 대시보드 공개 URL)
WEB_URL=http://YOUR_SERVER_IP:4000

# 웹 → API 내부 통신 (Docker 내부 DNS, 변경 불필요)
API_INTERNAL_URL=http://api:3000

# OAuth 로그인 리다이렉트용 (브라우저가 접근하는 공개 API URL)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:3000

# ─── Gemini API ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Lavalink (음악 재생) ────────────────────────────────
LAVALINK_URL=lavalink:2333
LAVALINK_PASSWORD=youshallnotpass

# ─── Spotify (필수, Spotify 검색 + Deezer 스트리밍) ──────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ─── Deezer (필수, 스트리밍 복호화 키) ───────────────────
DEEZER_MASTER_KEY=your_deezer_master_key

# ─── Monitoring ──────────────────────────────────────────
# Grafana admin 계정 (프로덕션에서는 반드시 변경)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_STRONG_GRAFANA_PASSWORD

# Alertmanager Discord Webhook URL
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
