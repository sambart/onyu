# ============================================================
# Production Environment Variables
# 복사하여 .env.prod 로 저장 후 실제 값을 채워 넣으세요.
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# ─── Server ───────────────────────────────────────────────
# 서버 공인 IP 또는 도메인 (예: 123.45.67.89)
SERVER_HOST=YOUR_SERVER_IP

# ─── Node ─────────────────────────────────────────────────
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=dhyun
DATABASE_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DATABASE_NAME=onyu

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ─── Discord Bot ──────────────────────────────────────────
DISCORD_API_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_COMMAND_PREFIX=!

# Discord OAuth 콜백 (도메인 기반 HTTPS)
DISCORD_CALLBACK_URL=https://api.onyu.dev/auth/discord/callback

# ─── Bot → API 통신 ─────────────────────────────────────
# Bot과 API 간 내부 통신 인증 키 (임의의 긴 문자열)
BOT_API_KEY=CHANGE_ME_RANDOM_BOT_API_KEY

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_JWT_SECRET

# ─── 플랫폼 슈퍼 관리자 ───────────────────────────────────
# read-only 콘솔(/admin) 접근 허용 Discord user ID, 쉼표 구분. 비우면 0명.
SUPER_ADMIN_IDS=

# ─── Web Dashboard ────────────────────────────────────────
# API CORS origin (웹 대시보드 공개 URL)
WEB_URL=https://onyu.dev

# 웹 → API 내부 통신 (Docker 내부 DNS, 변경 불필요)
API_INTERNAL_URL=http://api:3000

# OAuth 로그인 리다이렉트용 (브라우저가 접근하는 공개 API URL)
NEXT_PUBLIC_API_URL=https://api.onyu.dev

# ─── Gemini API ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
