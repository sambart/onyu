{
  "name": "onyu-monorepo",
  "version": "1.18.0",
  "description": "Discord bot monorepo with NestJS API and Next.js Web",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core",
      "esbuild",
      "ffmpeg-static",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "@discordjs/voice>discord-api-types": "0.38.42"
    }
  },
  "scripts": {
    "api:dev": "pnpm --filter @onyu/api start:dev",
    "api:build": "pnpm --filter @onyu/api build",
    "api:start": "pnpm --filter @onyu/api start",
    "api:start:prod": "pnpm --filter @onyu/api start:prod",
    "api:test": "pnpm --filter @onyu/api test",
    "api:test:e2e": "pnpm --filter @onyu/api test:e2e",
    "api:test:integration": "pnpm --filter @onyu/api test:integration",
    "web:dev": "pnpm --filter @onyu/web dev",
    "web:build": "pnpm --filter @onyu/web build",
    "web:start": "pnpm --filter @onyu/web start",
    "build": "pnpm -r run build",
    "format": "prettier --write \"apps/*/src/**/*.{ts,tsx}\" \"libs/*/src/**/*.ts\"",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "format:check": "prettier --check \"apps/*/src/**/*.{ts,tsx}\" \"libs/*/src/**/*.ts\"",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "postinstall": "pnpm -r run postinstall",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/node": "^20.3.1",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.0.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.50.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "lint-staged": {
    "apps/api/src/**/*.{ts,tsx}": [
      "eslint --fix --config apps/api/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/bot/src/**/*.{ts,tsx}": [
      "eslint --fix --config apps/bot/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/web/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "libs/shared/src/**/*.ts": [
      "eslint --fix --config libs/shared/eslint.config.mjs",
      "prettier --write"
    ],
    "libs/bot-api-client/src/**/*.ts": [
      "prettier --write"
    ]
  }
}
