  "help": {
    "title": "Help",
    "subtitle": "Frequently asked questions about Onyu features.",
    "contactTitle": "Still have questions?",
    "contactDesc": "Type the {command} command in Discord or contact an admin.",
    "sections": {
      "voice": {
        "title": "Voice Activity Tracking",
        "q1": "What data is recorded?",
        "a1": "The time a member joins and leaves a voice channel, as well as cumulative time per channel, are recorded. All voice channels in the server are tracked by default. Mute and video status are not recorded.",
        "q2": "How do I exclude channels?",
        "a2": "Go to Settings → Voice Tracking to select channels to exclude from tracking. Use this to exclude AFK channels or admin-only channels that don't need to be recorded."
      },
      "gemini": {
        "title": "AI Analysis (Gemini)",
        "q1": "How do I use Gemini AI analysis?",
        "a1": "Use slash commands in Discord. The bot analyzes voice activity data from the past 7 days and generates a report summarizing peak hours, key participants, and activity trends.",
        "q2": "What is the slash command?",
        "a2": "Enter the /voice-report command to generate an AI analysis report. Report generation may take up to 10 seconds. Only members with admin privileges can use this command."
      },
      "newbie": {
        "title": "Newbie Management",
        "q1": "How do I create missions?",
        "a1": "Go to Settings → Newbie Management to configure the mission list for new members. Set the mission type (voice channel participation, message sending, etc.), target, and completion reward role. New members who join after configuration will automatically receive missions.",
        "q2": "What is Moco hunting?",
        "a2": "A feature to identify members who joined the server but have not been active for a period after completing the newbie mission. Used to manage 'ghost members' who joined but don't actively participate."
      },
      "inactive": {
        "title": "Inactive Members",
        "q1": "What are the inactivity classification criteria?",
        "a1": "Members with no voice channel activity during the configured period (default 30 days) are classified as inactive. Grades are divided into warning, caution, and inactive based on configured criteria.",
        "q2": "How does automatic action work?",
        "a2": "The bot automatically runs classification according to the inactive member classification schedule (default weekly). After classification, you can configure automatic actions such as notifying a designated channel, assigning or removing specific roles. Actual kicks are not done automatically and must be performed by an admin."
      },
      "coPresence": {
        "title": "Relationship Analysis (Co-presence)",
        "q1": "How is the intimacy score calculated?",
        "a1": "The score is calculated based on the cumulative time two members were simultaneously in the same voice channel. The longer they spent together, the higher the intimacy score. You can visually check the connection strength between members in the relationship analysis graph."
      },
      "autoChannel": {
        "title": "Auto Channel Creation",
        "q1": "How do I set up a trigger channel?",
        "a1": "Go to Settings → Auto Channel to designate a trigger channel. When a member enters the trigger channel, the bot automatically creates a new voice channel and moves the member. The channel is automatically deleted when empty."
      }
    }
  },
